# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production, set to https://bankxlai.com

# Set to true for local testing without auth (skips login/usage checks)
SKIP_AUTH=false

# ─── Supabase ───────────────────────────────────────────────
# Get these from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Gemini AI (FREE tier) ──────────────────────────────────
# Free: 1,500 requests/day, 15 req/min
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ─── Razorpay ───────────────────────────────────────────────
# Sign up: https://dashboard.razorpay.com/signup
# Settings → API Keys → Generate key (test or live)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# Razorpay Plan IDs — create in Dashboard → Subscriptions → Plans
# IMPORTANT: plans created in TEST mode work only with TEST keys (and same for LIVE).
# Day Pass + Top-up use Razorpay Orders (not Plans), no env IDs needed.
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxx        # ₹499/month — 800 pages/month
RAZORPAY_PLAN_PRO_ANNUAL=plan_xxx         # ₹4,999/year — 800 pages/month
RAZORPAY_PLAN_FIRM_MONTHLY=plan_xxx       # ₹4,999/month — 8,000 pages/month
RAZORPAY_PLAN_FIRM_ANNUAL=plan_xxx        # ₹49,999/year — 8,000 pages/month
